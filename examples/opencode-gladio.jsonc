{
  "default_mode": "coordinator",
  "set_default_agent": true,
  "hooks": {
    "profile": "standard",
    "comment_guard": true,
    "session_start": true,
    "pre_tool_use": true,
    "post_tool_use": true,
    "pre_compact": true,
    "stop": true,
    "session_end": true,
    "file_edited": true,
    "prompt_refiner": false
  },
  "mcps": {
    "context7": true,
    "grep_app": true,
    "websearch": true,
    "fff": true,
    "web_agent_mcp": true,
    "pg_mcp": true,
    "ssh_mcp": true,
    "sudo_mcp": false,
    "jina": true,
    "figma_console": true,
    "mariadb": true
  },
  "agents": {
    "polat": {
      "variant": "xhigh"
    },
    "cakir": {
      "variant": "high"
    },
    "memati": {
      "variant": "high"
    },
    "abdulhey": {
      "variant": "none"
    },
    "aslan-akbey": {
      "variant": "xhigh"
    },
    "iskender": {
      "variant": "xhigh"
    },
    "tuncay": {
      "variant": "high"
    },
    "halit": {
      "variant": "none"
    },
    "gullu-erhan": {
      "variant": "high"
    },
    "laz-ziya": {
      "variant": "none"
    },
    "pala": {
      "variant": "high"
    }
  }
}
