{
  "schema_version": 2,
  "default_mode": "coordinator",
  "set_default_agent": true,
  "ui": {
    "worker_visibility": "visible"
  },
  "hooks": {
    "profile": "standard",
    "session_start": true,
    "pre_tool_use": true,
    "post_tool_use": true,
    "pre_compact": true,
    "stop": true,
    "session_end": true,
    "file_edited": true
  },
  "mcps": {
    "context7": true,
    "grep_app": true,
    "websearch": true
  },
  "fallbacks": {
    "enabled": true,
    "chains": {}
  },
  "multiplexer": {
    "type": "none",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "agents": {
    "polat": {
      "variant": "xhigh"
    },
    "cakir": {
      "variant": "none"
    },
    "memati": {
      "variant": "high"
    },
    "abdulhey": {
      "variant": "none"
    },
    "aslan-akbey": {
      "variant": "xhigh"
    },
    "iskender": {
      "variant": "xhigh"
    },
    "tuncay": {
      "variant": "high"
    },
    "halit": {
      "variant": "none"
    },
    "gullu-erhan": {
      "variant": "high"
    },
    "laz-ziya": {
      "variant": "none"
    },
    "pala": {
      "variant": "high"
    }
  }
}
