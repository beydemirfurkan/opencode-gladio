{
  "name": "opencode-gladio",
  "version": "0.5.0",
  "description": "Disciplined orchestration plugin for OpenCode. Automatic 4-tier workflow pipeline, dual review, pipeline integrity hooks, and persistent project memory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-gladio": "bin/opencode-gladio.js"
  },
  "files": [
    "dist",
    "bin",
    "opencode-gladio.schema.json",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "harness",
    "orchestration",
    "pipeline",
    "review",
    "fallback",
    "multiplexer"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beydemirfurkan/opencode-gladio.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "bun-types": "1.3.6",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
